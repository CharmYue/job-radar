{
  "manifest_version": 3,
  "name": "Boss 求职雷达",
  "version": "5.2.0",
  "description": "Boss直聘批量采集 + DeepSeek AI 适配度打分 + WxPusher 微信推送一体化。",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "windows",
    "alarms"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://*.zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://ark.cn-beijing.volces.com/*",
    "https://api.minimax.chat/*",
    "https://open.bigmodel.cn/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://wxpusher.zjiecode.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Boss 求职雷达"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/web/geek/job*"],
      "js": ["injected.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.zhipin.com/web/geek/job*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dict.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
