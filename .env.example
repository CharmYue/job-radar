# DeepSeek (primary scorer). Code accepts either name.
DEEP_SEEK_API=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx       # fallback name, also accepted

# Azure OpenAI (fallback scorer). Code accepts either base-url name.
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
# AZURE_OPENAI_ENDPOINT=...     # fallback name, also accepted
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# WxPusher (only required when running without --dry-run)
WXPUSHER_APP_TOKEN=AT_xxxx
WXPUSHER_UID=UID_xxxx
